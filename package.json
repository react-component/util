{
  "name": "@rc-component/util",
  "version": "1.11.1",
  "description": "Shared React utilities for rc-component packages.",
  "keywords": [
    "react",
    "util"
  ],
  "homepage": "http://github.com/react-component/util",
  "bugs": {
    "url": "http://github.com/react-component/util/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:react-component/util.git"
  },
  "license": "MIT",
  "main": "./lib/index",
  "module": "./es/index",
  "files": [
    "lib",
    "es"
  ],
  "scripts": {
    "build": "npm run compile && npm run docs:build",
    "compile": "father build",
    "coverage": "rc-test --coverage",
    "docs:build": "dumi build",
    "docs:deploy": "gh-pages -d docs-dist",
    "deploy": "npm run gh-pages",
    "gh-pages": "npm run compile && cross-env GH_PAGES=1 npm run docs:build && npm run docs:deploy",
    "lint": "eslint src/ tests/ docs/examples/ --ext .tsx,.ts,.jsx,.js",
    "prepublishOnly": "npm run compile && rc-np",
    "prettier": "prettier --write --ignore-unknown .",
    "start": "dumi dev",
    "test": "rc-test",
    "tsc": "tsc --noEmit"
  },
  "lint-staged": {
    "**/*.{js,jsx,tsx,ts,md,json}": [
      "prettier --write",
      "git add"
    ]
  },
  "dependencies": {
    "is-mobile": "^5.0.0",
    "react-is": "^18.2.0"
  },
  "devDependencies": {
    "@rc-component/father-plugin": "^2.2.0",
    "@rc-component/np": "^1.0.3",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.2",
    "@types/react-is": "^19.0.0",
    "@types/responselike": "^1.0.0",
    "@types/warning": "^3.0.0",
    "@umijs/fabric": "^3.0.0",
    "cross-env": "^10.1.0",
    "dumi": "^2.1.3",
    "eslint": "^8.54.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-unicorn": "^56.0.1",
    "father": "^4.1.3",
    "glob": "^13.0.0",
    "husky": "^9.1.6",
    "lint-staged": "^17.0.3",
    "prettier": "^3.3.2",
    "rc-test": "^7.0.14",
    "react": "^18.0.0",
    "react-19": "npm:react@19.0.0",
    "react-dom": "^18.0.0",
    "react-dom-19": "npm:react-dom@19.0.0",
    "typescript": "^5.3.2",
    "gh-pages": "^6.3.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
