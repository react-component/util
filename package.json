{
  "name": "@rc-component/util",
  "version": "1.11.1",
  "description": "Shared React utilities for rc-component packages.",
  "keywords": [
    "react",
    "util"
  ],
  "homepage": "https://react-component.github.io/util",
  "bugs": {
    "url": "https://github.com/react-component/util/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/react-component/util.git"
  },
  "license": "MIT",
  "main": "./lib/index",
  "module": "./es/index",
  "files": [
    "lib",
    "es"
  ],
  "scripts": {
    "build": "npm run compile && npm run docs:build",
    "compile": "father build",
    "coverage": "rc-test --coverage",
    "docs:build": "dumi build",
    "docs:deploy": "gh-pages -d docs-dist",
    "deploy": "npm run gh-pages",
    "gh-pages": "npm run compile && cross-env GH_PAGES=1 npm run docs:build && npm run docs:deploy",
    "lint": "eslint src/ tests/ docs/examples/ --ext .tsx,.ts,.jsx,.js",
    "prepublishOnly": "npm run compile && rc-np",
    "prettier": "prettier --write --ignore-unknown .",
    "start": "dumi dev",
    "test": "rc-test",
    "tsc": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "is-mobile": "^5.0.0",
    "react-is": "^18.2.0"
  },
  "devDependencies": {
    "@rc-component/father-plugin": "^2.2.0",
    "@rc-component/np": "^1.0.4",
    "@testing-library/react": "^15.0.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/react-is": "^19.0.0",
    "@types/responselike": "^1.0.0",
    "@types/warning": "^3.0.4",
    "@umijs/fabric": "^4.0.1",
    "cross-env": "^10.1.0",
    "dumi": "^2.4.35",
    "eslint": "^8.57.1",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "father": "^4.6.23",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.0",
    "rc-test": "^7.1.3",
    "react": "^18.3.1",
    "react-19": "npm:react@19.0.0",
    "react-dom": "^18.3.1",
    "react-dom-19": "npm:react-dom@19.0.0",
    "typescript": "^5.9.3",
    "gh-pages": "^6.3.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./es/index.d.ts"
}
