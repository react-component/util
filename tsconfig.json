{
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "node",
    "baseUrl": "./",
    "jsx": "preserve",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@@/*": [
        ".dumi/tmp/*"
      ],
      "@rc-component/util": [
        "src/index.ts"
      ],
      "@rc-component/util/es": [
        "src"
      ],
      "@rc-component/util/es/*": [
        "src/*"
      ],
      "rc-util": [
        "src/index.ts"
      ],
      "rc-util/es": [
        "src"
      ],
      "rc-util/es/*": [
        "src/*"
      ]
    },
    "ignoreDeprecations": "5.0"
  },
  "include": [
    ".dumirc.ts",
    "src",
    "tests",
    "docs/examples"
  ],
  "exclude": [
    "docs-dist",
    "lib",
    "es"
  ]
}
